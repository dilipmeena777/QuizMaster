<div class="container mt-4">
    <div class="row">

        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5>Total Users</h5>
                    <h2>@ViewBag.TotalUsers</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5>Total Questions</h5>
                    <h2>@ViewBag.TotalQuestions</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3">
                <div class="card-body">
                    <h5>Total Attempts</h5>
                    <h2>@ViewBag.TotalAttempts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-danger mb-3">
                <div class="card-body">
                    <h5>Top Score</h5>
                    <h2>@ViewBag.TopScore</h2>
                </div>
            </div>
        </div>

    </div>
</div>