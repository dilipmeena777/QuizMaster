@model List<Question>

<div class="container mt-4">

    <h2 class="text-center mb-4">📋 Manage Questions</h2>

    <!-- 🔍 Search -->
    <input type="text" id="searchBox" class="form-control mb-3" placeholder="Search question..." onkeyup="searchQuestion()" />

    <!-- ➕ Add Button -->
    <div class="text-end mb-3">
        <a href="/Admin/Create" class="btn btn-success">➕ Add Question</a>
    </div>

    <!-- 📊 Count -->
    <p>Total Questions: <b>@Model.Count</b></p>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Question</th>
                <th>Options</th>
                <th>Correct</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody id="questionTable">

            @for (int i = 0; i < Model.Count; i++)
            {
                <tr>
                    <td>@(i + 1)</td>
                    <td>@Model[i].QuestionText</td>
                    <td>
                        A: @Model[i].OptionA <br />
                        B: @Model[i].OptionB <br />
                        C: @Model[i].OptionC <br />
                        D: @Model[i].OptionD
                    </td>
                    <td>@Model[i].CorrectOption</td>
                    <td>
                        <a href="/Admin/Edit/@Model[i].Id" class="btn btn-warning btn-sm">✏ Edit</a>

                        <a href="/Admin/Delete/@Model[i].Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure?')">
                            🗑 Delete
                        </a>
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>

<script>
    function searchQuestion() {
        var input = document.getElementById("searchBox").value.toLowerCase();
        var rows = document.getElementById("questionTable").getElementsByTagName("tr");

        for (var i = 0; i < rows.length; i++) {
            var text = rows[i].innerText.toLowerCase();
            rows[i].style.display = text.includes(input) ? "" : "none";
        }
    }
</script>