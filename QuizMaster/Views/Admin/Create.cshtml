@model Question

<div class="container mt-4">

    <h2 class="text-center mb-4">➕ Add New Question</h2>

    <form method="post">

        <div class="mb-3">
            <label>Question</label>
            <input type="text" name="QuestionText" class="form-control" required />
        </div>

        <div class="row">
            <div class="col">
                <input type="text" name="OptionA" placeholder="Option A" class="form-control" required />
            </div>
            <div class="col">
                <input type="text" name="OptionB" placeholder="Option B" class="form-control" required />
            </div>
        </div>

        <div class="row mt-2">
            <div class="col">
                <input type="text" name="OptionC" placeholder="Option C" class="form-control" required />
            </div>
            <div class="col">
                <input type="text" name="OptionD" placeholder="Option D" class="form-control" required />
            </div>
        </div>

        <div class="mt-3">
            <label>Correct Option (A/B/C/D)</label>
            <input type="text" name="CorrectOption" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-success mt-3">Save</button>

    </form>

</div>